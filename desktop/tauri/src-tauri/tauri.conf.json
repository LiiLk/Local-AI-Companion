{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Local AI Companion Desktop",
  "version": "0.1.0",
  "identifier": "com.khalil.localaicompanion.desktop",
  "build": {
    "frontendDist": "../../../frontend/live2d"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "capabilities": [
        "default"
      ],
      "csp": null
    },
    "windows": [
      {
        "label": "main",
        "title": "Local AI Companion",
        "url": "index.html?backendPort=8765",
        "width": 420,
        "height": 760,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": true,
        "skipTaskbar": false,
        "shadow": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  }
}
