{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Local AI Companion Desktop",
  "version": "0.1.0",
  "identifier": "com.khalil.localaicompanion.desktop",
  "build": {
    "frontendDist": "../../../frontend/live2d"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "capabilities": [
        "default"
      ],
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: asset: http://asset.localhost; media-src 'self' data: blob: asset: http://asset.localhost; font-src 'self' data:; connect-src 'self' ws://127.0.0.1:8765 http://127.0.0.1:8765; object-src 'none'; base-uri 'self'; frame-ancestors 'none'"
    },
    "windows": [
      {
        "label": "main",
        "title": "Local AI Companion",
        "url": "index.html?backendPort=8765",
        "width": 420,
        "height": 760,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visible": true,
        "skipTaskbar": false,
        "shadow": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  }
}
